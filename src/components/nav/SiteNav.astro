---
import { href } from '../../lib/href';
import { t, type UIKey } from '../../i18n/ui';

// 各板块均已落地;upcoming 标记保留以便未来新增板块时不留死链。
// 导航文案走 i18n 字典(t),为多语言预留;新增语言只需在 ui.ts 补译。
const items: { key: UIKey; to: string; upcoming: boolean }[] = [
  { key: 'nav.timeline', to: 'timeline', upcoming: false },
  { key: 'nav.theory', to: 'theory', upcoming: false },
  { key: 'nav.engineering', to: 'engineering', upcoming: false },
  { key: 'nav.scientists', to: 'scientists', upcoming: false },
  { key: 'nav.insights', to: 'insights', upcoming: false },
  { key: 'nav.resources', to: 'resources', upcoming: false },
];
---

<nav id="site-nav" aria-label="主导航">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
    <a href={href('/')} class="text-base font-bold tracking-wide text-text">
      <span class="text-arc-gold">⚡</span> {t('nav.brand')}
    </a>

    <!-- 桌面导航 -->
    <ul class="hidden items-center gap-6 text-sm md:flex">
      {
        items.map((it) =>
          it.upcoming ? (
            <li>
              <span aria-disabled="true" class="cursor-not-allowed text-text-dim/50" title="即将上线">
                {t(it.key)}
              </span>
            </li>
          ) : (
            <li>
              <a href={href(it.to)} class="text-text-dim transition hover:text-arc-gold">
                {t(it.key)}
              </a>
            </li>
          ),
        )
      }
    </ul>

    <!-- 移动端:只给主入口 -->
    <a href={href('timeline')} class="text-sm text-arc-gold md:hidden">{t('nav.timelineShort')} →</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  #site-nav {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    background: rgba(15, 23, 42, 0.35);
    backdrop-filter: blur(2px);
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  #site-nav.scrolled {
    background: rgba(11, 17, 32, 0.92);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--color-line);
  }
</style>
