---
import { href } from '../../lib/href';

// 本轮仅时间线真实可达;其余板块标 upcoming,渲染为 aria-disabled,不留死链。
const items = [
  { label: '交互式时间线', to: 'timeline', upcoming: false },
  { label: '理论与争议', to: 'theory', upcoming: false },
  { label: '工程应用史', to: '', upcoming: true },
  { label: '科学家列传', to: 'scientists', upcoming: false },
  { label: '科学启示录', to: '', upcoming: true },
];
---

<nav id="site-nav" aria-label="主导航">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
    <a href={href('/')} class="text-base font-bold tracking-wide text-text">
      <span class="text-arc-gold">⚡</span> 电磁学
    </a>

    <!-- 桌面导航 -->
    <ul class="hidden items-center gap-6 text-sm md:flex">
      {
        items.map((it) =>
          it.upcoming ? (
            <li>
              <span aria-disabled="true" class="cursor-not-allowed text-text-dim/50" title="即将上线">
                {it.label}
              </span>
            </li>
          ) : (
            <li>
              <a href={href(it.to)} class="text-text-dim transition hover:text-arc-gold">
                {it.label}
              </a>
            </li>
          ),
        )
      }
    </ul>

    <!-- 移动端:只给主入口 -->
    <a href={href('timeline')} class="text-sm text-arc-gold md:hidden">时间线 →</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  #site-nav {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    background: rgba(15, 23, 42, 0.35);
    backdrop-filter: blur(2px);
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  #site-nav.scrolled {
    background: rgba(11, 17, 32, 0.92);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--color-line);
  }
</style>
