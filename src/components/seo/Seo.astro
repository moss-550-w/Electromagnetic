---
// 每页独立 title / meta / og(CLAUDE.md 六节硬要求)。canonical 含 site+base。
// 可选 image(og/twitter 预览图)、type(og:type)、jsonLd(结构化数据,单个或数组)。
import { SITE_NAME } from '../../lib/schema';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: object | object[];
}
const { title, description, image, type = 'website', jsonLd } = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;
const ogImage = image
  ? Astro.site
    ? new URL(image, Astro.site).href
    : image
  : undefined;
const schemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
// JSON-LD 注入防御:转义 < 以免数据里意外出现 </script> 截断脚本块
const ldJson = (o: object) => JSON.stringify(o).replace(/</g, '\\u003c');
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
{schemas.map((s) => <script type="application/ld+json" is:inline set:html={ldJson(s)} />)}
