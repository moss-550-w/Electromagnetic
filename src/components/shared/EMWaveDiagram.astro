---
// 电磁波可视化:电场 E(红)与磁场 B(蓝)同相振荡、彼此垂直,沿传播方向前进。
// 构建时生成正弦路径,纯静态 SVG(无动画依赖,a11y 友好)。
const W = 400;
const mid = 100;
const ampE = 55;
const ampB = 34;
const lambda = 130;
const k = (2 * Math.PI) / lambda;

const xs: number[] = [];
for (let x = 0; x <= W; x += 4) xs.push(x);
const ePath = 'M ' + xs.map((x) => `${x},${(mid - ampE * Math.sin(k * x)).toFixed(1)}`).join(' L ');
const bPath = 'M ' + xs.map((x) => `${x},${(mid - ampB * Math.sin(k * x)).toFixed(1)}`).join(' L ');
---

<figure class="rounded-xl border border-line bg-panel p-5">
  <svg
    viewBox="0 0 400 200"
    class="w-full"
    role="img"
    aria-label="电磁波示意图:电场 E 与磁场 B 同相振荡、彼此垂直,沿传播方向以光速前进"
  >
    <line x1="0" y1="100" x2="400" y2="100" stroke="#475569" stroke-width="1" stroke-dasharray="4 4" />
    <path d={bPath} fill="none" stroke="#3B82F6" stroke-width="2" opacity="0.85" />
    <path d={ePath} fill="none" stroke="#EF4444" stroke-width="2.5" />
    <polygon points="388,94 400,100 388,106" fill="#F59E0B" />
    <text x="6" y="26" fill="#EF4444" font-size="13" font-weight="bold">E 电场</text>
    <text x="6" y="188" fill="#3B82F6" font-size="13" font-weight="bold">B 磁场</text>
    <text x="288" y="92" fill="#F59E0B" font-size="11">传播 → 光速 c</text>
  </svg>
  <figcaption class="mt-2 text-center text-[13px] leading-6 text-text-dim">
    电场(红)与磁场(蓝)同相振荡、互相垂直,彼此激发、手拉手向前奔跑——这就是光。
  </figcaption>
</figure>
