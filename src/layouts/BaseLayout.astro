---
// Inter self-host(@fontsource:字体文件随包打进 dist,无外网依赖)
import '@fontsource/inter/400.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';
import Seo from '../components/seo/Seo.astro';
import { asset } from '../lib/href';

interface Props {
  title: string;
  description: string;
  lang?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: object | object[];
}
const { title, description, lang = 'zh-CN', image, type, jsonLd } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
    <Seo title={title} description={description} image={image} type={type} jsonLd={jsonLd} />
    <slot name="head" />
  </head>
  <body class="bg-bg text-text font-sans antialiased">
    <a href="#main" class="skip-link">跳到主内容</a>
    <slot />
  </body>
</html>
