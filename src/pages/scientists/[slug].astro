---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import { getCollection } from 'astro:content';
import { getTheory } from '../../lib/data';
import { href } from '../../lib/href';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const scientists = await getCollection('scientists');
  return scientists.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const scientist = entry.data;
const theory = scientist.theorySlug ? await getTheory(scientist.theorySlug) : null;

// 6 段:前 5 段 + 名言(design.md 5.2)
const SECTIONS = [
  { key: 'portrait', label: '凡人画像', sub: '性格、缺点与人生困境' },
  { key: 'journey', label: '研究之路', sub: '不是一帆风顺,而是充满挫折' },
  { key: 'contribution', label: '核心贡献', sub: '客观评价,不夸大' },
  { key: 'controversy', label: '他们的争议', sub: '当时的人如何评价' },
  { key: 'legacy', label: '留给后世的启示', sub: '' },
] as const;

const origin = Astro.site;
const abs = (p: string): string => (origin ? new URL(p, origin).href : p);
const pageUrl = abs(Astro.url.pathname);
const jsonLd = [
  articleSchema({
    headline: scientist.name,
    description: scientist.summary,
    url: pageUrl,
    section: '凡人科学家列传',
  }),
  breadcrumbSchema([
    { name: '首页', url: abs(import.meta.env.BASE_URL) },
    { name: '凡人科学家列传', url: abs(href('scientists')) },
    { name: scientist.name, url: pageUrl },
  ]),
];
---

<BaseLayout title={`${scientist.name} · 凡人科学家列传`} description={scientist.summary} type="article" jsonLd={jsonLd}>
  <SiteNav />
  <main id="main" class="mx-auto max-w-3xl px-5 pb-24 pt-24">
    <a href={href('scientists')} class="text-sm text-text-dim transition hover:text-arc-gold">← 凡人科学家列传</a>

    <header class="mt-4 border-b border-line pb-8">
      <div class="text-sm font-bold" style={`color:${scientist.accent}`}>
        {scientist.life} · {scientist.role}
      </div>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight">{scientist.name}</h1>
      <p class="mt-5 rounded-xl border border-line bg-panel p-4 leading-relaxed">
        <span class="font-semibold text-arc-gold">凡人特质:</span>{scientist.summary}
      </p>
    </header>

    <article class="mt-10 flex flex-col gap-10">
      {
        SECTIONS.map((s, i) => (
          <section aria-labelledby={`sec-${s.key}`}>
            <div class="flex items-baseline gap-3">
              <span class="text-2xl font-extrabold tabular-nums" style={`color:${scientist.accent}`}>
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h2 id={`sec-${s.key}`} class="text-xl font-bold">{s.label}</h2>
                {s.sub && <p class="text-xs text-text-dim">{s.sub}</p>}
              </div>
            </div>

            {s.key !== 'legacy' && s.key !== 'controversy' && (
              <p class="mt-3 text-[15px] leading-8 text-text">{scientist.sections[s.key]}</p>
            )}

            {s.key === 'controversy' && (
              <div class="mt-3 rounded-r-lg border-l-4 border-charge-pos/60 bg-charge-pos/5 px-4 py-3 text-[15px] leading-8">
                {scientist.sections.controversy}
              </div>
            )}

            {s.key === 'legacy' && (
              <blockquote class="mt-3 border-l-4 border-arc-gold bg-panel-2 px-4 py-3 italic text-text">
                「 {scientist.sections.legacy} 」
              </blockquote>
            )}
          </section>
        ))
      }
    </article>

    <!-- 第 6 部分:他们的名言 -->
    <figure class="mt-12 rounded-2xl border border-line bg-panel p-7 text-center">
      <blockquote class="text-xl font-semibold leading-relaxed text-text">“{scientist.quote.zh}”</blockquote>
      {scientist.quote.en && <p class="mt-3 text-sm italic text-text-dim">{scientist.quote.en}</p>}
      <figcaption class="mt-4 text-sm" style={`color:${scientist.accent}`}>—— {scientist.name}</figcaption>
    </figure>

    {
      theory && (
        <nav class="mt-10 border-t border-line pt-6 text-sm">
          <a href={href(`theory/${theory.id}`)} class="text-arc-gold hover:underline">
            相关理论:{theory.data.name} →
          </a>
        </nav>
      )
    }
  </main>
</BaseLayout>
