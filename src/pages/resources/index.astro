---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import FieldLines from '../../components/interactive/FieldLines.tsx';
import EMWaveApp from '../../components/interactive/EMWaveApp.tsx';
import QuizApp from '../../components/interactive/QuizApp.tsx';
import PosterDownload from '../../components/interactive/PosterDownload.tsx';
import {
  RESOURCES_INTRO,
  VIDEOS,
  BOOKS,
  PAPERS,
  EXPERIMENTS,
} from '../../data/resources';
import { ERAS } from '../../data/timeline';
import { getAllScientists } from '../../lib/data';
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';
import katex from 'katex';
import 'katex/dist/katex.min.css';

const origin = Astro.site;
const abs = (p: string): string => (origin ? new URL(p, origin).href : p);
const pageUrl = abs(Astro.url.pathname);
const jsonLd = [
  webPageSchema({
    name: '资源中心',
    description: '延伸观看与阅读、原始文献库、十个在家可做的电磁学实验复刻指南、高清素材下载,以及电场线、电磁波、认知闯关三大交互。',
    url: pageUrl,
  }),
  breadcrumbSchema([
    { name: '首页', url: abs(import.meta.env.BASE_URL) },
    { name: '资源中心', url: pageUrl },
  ]),
];

// 预渲染海报中的 KaTeX 公式(构建时,零运行时开销)
const eq = (tex: string) => katex.renderToString(tex, { displayMode: true, throwOnError: false });

// 科学家海报数据
const scientistEntries = await getAllScientists();
---

<BaseLayout
  title="资源中心 · 电磁学认知革命"
  description="延伸观看与阅读、原始文献库、十个在家可做的电磁学实验复刻指南、高清素材下载,以及电场线、电磁波、认知闯关三大交互。"
  jsonLd={jsonLd}
>
  <SiteNav />
  <main id="main" class="mx-auto max-w-5xl px-5 pb-24 pt-24">
    <header class="max-w-2xl">
      <h1 class="text-4xl font-extrabold md:text-5xl">资源中心</h1>
      <p class="mt-4 text-lg text-text-dim">{RESOURCES_INTRO}</p>
    </header>

    <!-- 页内目录 -->
    <nav aria-label="页内导航" class="mt-8 flex flex-wrap gap-2 text-sm">
      {
        [
          ['#interactions', '互动实验室'],
          ['#quiz', '认知闯关'],
          ['#videos', '视频'],
          ['#books', '书籍'],
          ['#papers', '原始文献'],
          ['#experiments', '实验复刻'],
          ['#downloads', '素材下载'],
        ].map(([h, label]) => (
          <a
            href={h}
            class="rounded-full border border-line px-3 py-1 text-text-dim transition hover:border-arc-gold/60 hover:text-arc-gold"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- ===== 互动实验室:电场线 + 电磁波 ===== -->
    <section id="interactions" class="mt-14 scroll-mt-24" aria-labelledby="interactions-title">
      <h2 id="interactions-title" class="text-2xl font-bold">互动实验室</h2>
      <p class="mt-2 text-sm text-text-dim">
        把抽象的「场」与「波」交到你手里——拖一拖、调一调,让它们变得可感知。
      </p>

      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">
          <span class="text-charge-pos">电场线</span>可视化
        </h3>
        <p class="mt-1 text-sm text-text-dim">拖动正负电荷,实时看电场线如何重新编织。</p>
        <div class="mt-5">
          <FieldLines client:visible />
        </div>
      </div>

      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">电磁波传播动画</h3>
        <p class="mt-1 text-sm text-text-dim">
          调节频率与振幅,观察 E 与 B 如何同相、垂直、以光速手拉手前进。
        </p>
        <div class="mt-5">
          <EMWaveApp client:visible />
        </div>
      </div>
    </section>

    <!-- ===== 认知闯关 ===== -->
    <section id="quiz" class="mt-14 scroll-mt-24" aria-labelledby="quiz-title">
      <h2 id="quiz-title" class="text-2xl font-bold">认知闯关</h2>
      <p class="mt-2 text-sm text-text-dim">
        10 道源自真实历史的选择题,通关可领取专属证书。
      </p>
      <div class="mt-6">
        <QuizApp client:visible />
      </div>
    </section>

    <!-- ===== 视频推荐 ===== -->
    <section id="videos" class="mt-14 scroll-mt-24" aria-labelledby="videos-title">
      <h2 id="videos-title" class="text-2xl font-bold">视频推荐</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {
          VIDEOS.map((v) => (
            <article class="rounded-xl border border-line bg-panel p-5">
              <div class="flex items-center justify-between">
                {v.tag && <span class="rounded-full bg-panel-2 px-2 py-0.5 text-[11px] text-text-dim">{v.tag}</span>}
              </div>
              <h3 class="mt-2 font-bold text-text">{v.title}</h3>
              <p class="mt-0.5 text-xs text-text-dim">{v.by}</p>
              <p class="mt-2 text-sm leading-7 text-text-dim">{v.desc}</p>
              {v.url && (
                <a href={v.url} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-sm font-semibold text-arc-gold hover:underline">
                  前往观看 →
                </a>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <!-- ===== 书籍推荐 ===== -->
    <section id="books" class="mt-14 scroll-mt-24" aria-labelledby="books-title">
      <h2 id="books-title" class="text-2xl font-bold">书籍推荐</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {
          BOOKS.map((b) => (
            <article class="flex gap-4 rounded-xl border border-line bg-panel p-5">
              <div class="grid h-12 w-9 shrink-0 place-items-center rounded bg-panel-2 text-arc-gold" aria-hidden="true">📖</div>
              <div>
                <div class="flex flex-wrap items-baseline gap-2">
                  <h3 class="font-bold text-text">{b.title}</h3>
                  {b.tag && <span class="text-[11px] text-text-dim">· {b.tag}</span>}
                </div>
                <p class="mt-0.5 text-xs text-text-dim">{b.by}</p>
                <p class="mt-2 text-sm leading-7 text-text-dim">{b.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ===== 原始文献库 ===== -->
    <section id="papers" class="mt-14 scroll-mt-24" aria-labelledby="papers-title">
      <h2 id="papers-title" class="text-2xl font-bold">原始文献库</h2>
      <p class="mt-2 text-sm text-text-dim">回到一手史料,看科学家亲笔写下的原文。</p>
      <ul class="mt-5 flex flex-col gap-3">
        {
          PAPERS.map((p) => (
            <li class="rounded-xl border border-line bg-panel p-5">
              <div class="flex flex-wrap items-baseline gap-2">
                <h3 class="font-bold text-text">{p.title}</h3>
                {p.tag && <span class="rounded-full bg-panel-2 px-2 py-0.5 text-[11px] text-text-dim">{p.tag}</span>}
              </div>
              <p class="mt-0.5 text-xs text-text-dim">{p.by}</p>
              <p class="mt-2 text-sm leading-7 text-text-dim">{p.desc}</p>
              {p.url && (
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-3 inline-block text-sm font-semibold text-arc-gold hover:underline"
                >
                  查看原文 →
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ===== 实验复刻指南 ===== -->
    <section id="experiments" class="mt-14 scroll-mt-24" aria-labelledby="exp-title">
      <h2 id="exp-title" class="text-2xl font-bold">实验复刻指南</h2>
      <p class="mt-2 text-sm text-text-dim">
        亲手重现历史上的关键瞬间——十个在家就能做的简单电磁学实验,顺着时间线从静电到电磁感应。
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {
          EXPERIMENTS.map((e) => (
            <article class="rounded-xl border border-line bg-panel p-5">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-bold text-text">{e.title}</h3>
                <span
                  class:list={[
                    'shrink-0 rounded-full px-2 py-0.5 text-[11px]',
                    e.level === '简单' ? 'bg-emerald-500/15 text-emerald-400' : 'bg-arc-gold/15 text-arc-gold',
                  ]}
                >
                  {e.level}
                </span>
              </div>
              <p class="mt-0.5 text-xs text-text-dim">复刻:{e.origin}</p>

              <div class="mt-3 text-xs">
                <span class="text-text-dim">材料:</span>
                <span class="text-text">{e.materials.join('、')}</span>
              </div>

              <ol class="mt-3 flex list-decimal flex-col gap-1.5 pl-5 text-sm leading-7 text-text-dim marker:text-arc-gold">
                {e.steps.map((s) => (
                  <li>{s}</li>
                ))}
              </ol>

              <p class="mt-3 rounded-lg bg-panel-2 px-3 py-2 text-[13px] leading-6 text-text-dim">
                <span class="font-semibold text-text">原理:</span>{e.principle}
              </p>

              {e.safety && (
                <p class="mt-2 rounded-lg border border-charge-pos/40 bg-charge-pos/10 px-3 py-2 text-[13px] leading-6">
                  <span class="font-semibold text-charge-pos">⚠ 安全:</span>
                  <span class="text-text-dim">{e.safety}</span>
                </p>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <!-- ===== 高清素材下载 ===== -->
    <section id="downloads" class="mt-14 scroll-mt-24" aria-labelledby="dl-title">
      <h2 id="dl-title" class="text-2xl font-bold">高清素材下载</h2>

      <!-- 1. 麦克斯韦方程组海报 -->
      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">麦克斯韦方程组海报</h3>
        <p class="mt-1 text-sm text-text-dim">四个方程的微分形式,配公式来源注释,适合打印张贴。</p>
        <div class="mt-5">
          <PosterDownload fileName="麦克斯韦方程组-电磁学认知革命.png" client:visible>
            <div style="padding:48px 40px;font-family:Inter,system-ui,sans-serif;min-height:520px">
              <div style="text-align:center;margin-bottom:36px">
                <h1 style="font-size:28px;font-weight:800;color:#F59E0B;margin:0 0 4px">麦克斯韦方程组</h1>
                <p style="font-size:15px;color:#94A3B8;margin:0">
                  四个方程统一电、磁、光 &nbsp;·&nbsp; James Clerk Maxwell, 1865
                </p>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:720px;margin:0 auto">
                <div style="background:#16223f;border-radius:12px;padding:20px 18px;border-left:3px solid #3B82F6">
                  <div style="font-size:11px;font-weight:700;color:#3B82F6;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">高斯电场定律 · 收编库仑定律</div>
                  <span set:html={eq('\\nabla \\cdot \\mathbf{E} = \\dfrac{\\rho}{\\varepsilon_0}')} />
                  <p style="font-size:12px;color:#94A3B8;margin:10px 0 0">电荷是电场的源,电场从正电荷发散。</p>
                </div>
                <div style="background:#16223f;border-radius:12px;padding:20px 18px;border-left:3px solid #64748B">
                  <div style="font-size:11px;font-weight:700;color:#64748B;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">高斯磁场定律 · 磁单极不存在</div>
                  <span set:html={eq('\\nabla \\cdot \\mathbf{B} = 0')} />
                  <p style="font-size:12px;color:#94A3B8;margin:10px 0 0">磁感线无头无尾、自成闭合。</p>
                </div>
                <div style="background:#16223f;border-radius:12px;padding:20px 18px;border-left:3px solid #EF4444">
                  <div style="font-size:11px;font-weight:700;color:#EF4444;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">法拉第电磁感应 · 十年实验</div>
                  <span set:html={eq('\\nabla \\times \\mathbf{E} = -\\dfrac{\\partial \\mathbf{B}}{\\partial t}')} />
                  <p style="font-size:12px;color:#94A3B8;margin:10px 0 0">变化的磁场,激发出电场。</p>
                </div>
                <div style="background:#16223f;border-radius:12px;padding:20px 18px;border-left:3px solid #A78BFA">
                  <div style="font-size:11px;font-weight:700;color:#A78BFA;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">安培–麦克斯韦 · 位移电流</div>
                  <span set:html={eq('\\nabla \\times \\mathbf{B} = \\mu_0 \\mathbf{J} + \\mu_0 \\varepsilon_0 \\dfrac{\\partial \\mathbf{E}}{\\partial t}')} />
                  <p style="font-size:12px;color:#94A3B8;margin:10px 0 0">电流与变化的电场,都会激发磁场——末项预言了电磁波。</p>
                </div>
              </div>
              <div style="text-align:center;margin-top:32px;padding-top:20px;border-top:1px solid #1e2c4a">
                <p style="font-size:12px;color:#64748B;margin:0">
                  电磁学认知革命 · moss-550-w.github.io/Electromagnetic
                </p>
              </div>
            </div>
          </PosterDownload>
        </div>
      </div>

      <!-- 2. 时间线海报 -->
      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">电磁学发展时间线海报</h3>
        <p class="mt-1 text-sm text-text-dim">关键节点一览,从泰勒斯到 5G,适合打印张贴。</p>
        <div class="mt-5">
          <PosterDownload fileName="电磁学发展时间线-电磁学认知革命.png" client:visible>
            <div style="padding:44px 40px;font-family:Inter,system-ui,sans-serif;min-height:580px">
              <div style="text-align:center;margin-bottom:32px">
                <h1 style="font-size:26px;font-weight:800;color:#F59E0B;margin:0 0 4px">电磁学发展时间线</h1>
                <p style="font-size:14px;color:#94A3B8;margin:0">
                  从琥珀摩擦到 5G 通信 · 一场跨越三千年的认知革命
                </p>
              </div>
              <div style="max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:0">
                {ERAS.flatMap((era) =>
                  era.nodes.filter(n => n.key).map((n) => (
                    <div style="display:flex;align-items:flex-start;gap:16px;padding:12px 0;border-bottom:1px solid #1e2c4a">
                      <div style="min-width:52px;text-align:right;font-size:13px;font-weight:700;color:#F59E0B;font-variant-numeric:tabular-nums">{n.year}</div>
                      <div style="width:2px;min-height:40px;background:{era.accent};border-radius:1px;margin-top:2px"></div>
                      <div>
                        <div style="font-size:14px;font-weight:700;color:#E2E8F0">{n.title}</div>
                        <div style="font-size:12px;color:#94A3B8;margin-top:2px">{n.person} · {era.name}</div>
                      </div>
                    </div>
                  ))
                )}
              </div>
              <div style="text-align:center;margin-top:28px;padding-top:18px;border-top:1px solid #1e2c4a">
                <p style="font-size:12px;color:#64748B;margin:0">
                  电磁学认知革命 · moss-550-w.github.io/Electromagnetic
                </p>
              </div>
            </div>
          </PosterDownload>
        </div>
      </div>

      <!-- 3. 科学家肖像合集 -->
      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">科学家肖像合集</h3>
        <p class="mt-1 text-sm text-text-dim">四位改变电磁学的凡人科学家,含名言与定位。</p>
        <div class="mt-5">
          <PosterDownload fileName="凡人科学家-电磁学认知革命.png" client:visible>
            <div style="padding:44px 40px;font-family:Inter,system-ui,sans-serif;min-height:440px">
              <div style="text-align:center;margin-bottom:30px">
                <h1 style="font-size:26px;font-weight:800;color:#F59E0B;margin:0 0 4px">凡人科学家</h1>
                <p style="font-size:14px;color:#94A3B8;margin:0">
                  他们和我们一样,只是更坚持、更愿意独立思考
                </p>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;max-width:680px;margin:0 auto">
                {scientistEntries.map((entry) => {
                  const s = entry.data;
                  return (
                    <div style="background:#16223f;border-radius:12px;padding:22px 20px;border-top:3px solid {s.accent};display:flex;flex-direction:column;gap:8px">
                      <div>
                        <div style="font-size:17px;font-weight:700;color:#E2E8F0">{s.name}</div>
                        <div style="font-size:12px;color:{s.accent};margin-top:1px">{s.life} · {s.role}</div>
                      </div>
                      <p style="font-size:13px;color:#94A3B8;line-height:1.7;margin:0;font-style:italic">
                        「{s.quote.zh.slice(0, 60)}{s.quote.zh.length > 60 ? '…' : ''}」
                      </p>
                    </div>
                  );
                })}
              </div>
              <div style="text-align:center;margin-top:26px;padding-top:16px;border-top:1px solid #1e2c4a">
                <p style="font-size:12px;color:#64748B;margin:0">
                  电磁学认知革命 · moss-550-w.github.io/Electromagnetic
                </p>
              </div>
            </div>
          </PosterDownload>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-line py-8 text-center text-xs text-text-dim">
    <p>所有外部资源版权归原作者所有,本站仅作学习推荐。</p>
  </footer>
</BaseLayout>
