---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import FieldLines from '../../components/interactive/FieldLines.tsx';
import EMWaveApp from '../../components/interactive/EMWaveApp.tsx';
import QuizApp from '../../components/interactive/QuizApp.tsx';
import {
  RESOURCES_INTRO,
  VIDEOS,
  BOOKS,
  PAPERS,
  EXPERIMENTS,
  DOWNLOADS,
} from '../../data/resources';
---

<BaseLayout
  title="资源中心 · 电磁学认知革命"
  description="延伸观看与阅读、原始文献库、十个在家可做的电磁学实验复刻指南、高清素材下载,以及电场线、电磁波、认知闯关三大交互。"
>
  <SiteNav />
  <main id="main" class="mx-auto max-w-5xl px-5 pb-24 pt-24">
    <header class="max-w-2xl">
      <h1 class="text-4xl font-extrabold md:text-5xl">资源中心</h1>
      <p class="mt-4 text-lg text-text-dim">{RESOURCES_INTRO}</p>
    </header>

    <!-- 页内目录 -->
    <nav aria-label="页内导航" class="mt-8 flex flex-wrap gap-2 text-sm">
      {
        [
          ['#interactions', '互动实验室'],
          ['#quiz', '认知闯关'],
          ['#videos', '视频'],
          ['#books', '书籍'],
          ['#papers', '原始文献'],
          ['#experiments', '实验复刻'],
          ['#downloads', '素材下载'],
        ].map(([h, label]) => (
          <a
            href={h}
            class="rounded-full border border-line px-3 py-1 text-text-dim transition hover:border-arc-gold/60 hover:text-arc-gold"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- ===== 互动实验室:电场线 + 电磁波 ===== -->
    <section id="interactions" class="mt-14 scroll-mt-24" aria-labelledby="interactions-title">
      <h2 id="interactions-title" class="text-2xl font-bold">互动实验室</h2>
      <p class="mt-2 text-sm text-text-dim">
        把抽象的「场」与「波」交到你手里——拖一拖、调一调,让它们变得可感知。
      </p>

      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">
          <span class="text-charge-pos">电场线</span>可视化
        </h3>
        <p class="mt-1 text-sm text-text-dim">拖动正负电荷,实时看电场线如何重新编织。</p>
        <div class="mt-5">
          <FieldLines client:visible />
        </div>
      </div>

      <div class="mt-6 rounded-2xl border border-line bg-panel/40 p-5 md:p-6">
        <h3 class="text-lg font-bold">电磁波传播动画</h3>
        <p class="mt-1 text-sm text-text-dim">
          调节频率与振幅,观察 E 与 B 如何同相、垂直、以光速手拉手前进。
        </p>
        <div class="mt-5">
          <EMWaveApp client:visible />
        </div>
      </div>
    </section>

    <!-- ===== 认知闯关 ===== -->
    <section id="quiz" class="mt-14 scroll-mt-24" aria-labelledby="quiz-title">
      <h2 id="quiz-title" class="text-2xl font-bold">认知闯关</h2>
      <p class="mt-2 text-sm text-text-dim">
        10 道源自真实历史的选择题,通关可领取专属证书。
      </p>
      <div class="mt-6">
        <QuizApp client:visible />
      </div>
    </section>

    <!-- ===== 视频推荐 ===== -->
    <section id="videos" class="mt-14 scroll-mt-24" aria-labelledby="videos-title">
      <h2 id="videos-title" class="text-2xl font-bold">视频推荐</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {
          VIDEOS.map((v) => (
            <article class="rounded-xl border border-line bg-panel p-5">
              <div class="flex items-center justify-between">
                {v.tag && <span class="rounded-full bg-panel-2 px-2 py-0.5 text-[11px] text-text-dim">{v.tag}</span>}
              </div>
              <h3 class="mt-2 font-bold text-text">{v.title}</h3>
              <p class="mt-0.5 text-xs text-text-dim">{v.by}</p>
              <p class="mt-2 text-sm leading-7 text-text-dim">{v.desc}</p>
              {v.url && (
                <a href={v.url} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-sm font-semibold text-arc-gold hover:underline">
                  前往观看 →
                </a>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <!-- ===== 书籍推荐 ===== -->
    <section id="books" class="mt-14 scroll-mt-24" aria-labelledby="books-title">
      <h2 id="books-title" class="text-2xl font-bold">书籍推荐</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {
          BOOKS.map((b) => (
            <article class="flex gap-4 rounded-xl border border-line bg-panel p-5">
              <div class="grid h-12 w-9 shrink-0 place-items-center rounded bg-panel-2 text-arc-gold" aria-hidden="true">📖</div>
              <div>
                <div class="flex flex-wrap items-baseline gap-2">
                  <h3 class="font-bold text-text">{b.title}</h3>
                  {b.tag && <span class="text-[11px] text-text-dim">· {b.tag}</span>}
                </div>
                <p class="mt-0.5 text-xs text-text-dim">{b.by}</p>
                <p class="mt-2 text-sm leading-7 text-text-dim">{b.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ===== 原始文献库 ===== -->
    <section id="papers" class="mt-14 scroll-mt-24" aria-labelledby="papers-title">
      <h2 id="papers-title" class="text-2xl font-bold">原始文献库</h2>
      <p class="mt-2 text-sm text-text-dim">回到一手史料,看科学家亲笔写下的原文。</p>
      <ul class="mt-5 flex flex-col gap-3">
        {
          PAPERS.map((p) => (
            <li class="rounded-xl border border-line bg-panel p-5">
              <div class="flex flex-wrap items-baseline gap-2">
                <h3 class="font-bold text-text">{p.title}</h3>
                {p.tag && <span class="rounded-full bg-panel-2 px-2 py-0.5 text-[11px] text-text-dim">{p.tag}</span>}
              </div>
              <p class="mt-0.5 text-xs text-text-dim">{p.by}</p>
              <p class="mt-2 text-sm leading-7 text-text-dim">{p.desc}</p>
              {p.url && (
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-3 inline-block text-sm font-semibold text-arc-gold hover:underline"
                >
                  查看原文 →
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ===== 实验复刻指南 ===== -->
    <section id="experiments" class="mt-14 scroll-mt-24" aria-labelledby="exp-title">
      <h2 id="exp-title" class="text-2xl font-bold">实验复刻指南</h2>
      <p class="mt-2 text-sm text-text-dim">
        亲手重现历史上的关键瞬间——十个在家就能做的简单电磁学实验,顺着时间线从静电到电磁感应。
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {
          EXPERIMENTS.map((e) => (
            <article class="rounded-xl border border-line bg-panel p-5">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-bold text-text">{e.title}</h3>
                <span
                  class:list={[
                    'shrink-0 rounded-full px-2 py-0.5 text-[11px]',
                    e.level === '简单' ? 'bg-emerald-500/15 text-emerald-400' : 'bg-arc-gold/15 text-arc-gold',
                  ]}
                >
                  {e.level}
                </span>
              </div>
              <p class="mt-0.5 text-xs text-text-dim">复刻:{e.origin}</p>

              <div class="mt-3 text-xs">
                <span class="text-text-dim">材料:</span>
                <span class="text-text">{e.materials.join('、')}</span>
              </div>

              <ol class="mt-3 flex list-decimal flex-col gap-1.5 pl-5 text-sm leading-7 text-text-dim marker:text-arc-gold">
                {e.steps.map((s) => (
                  <li>{s}</li>
                ))}
              </ol>

              <p class="mt-3 rounded-lg bg-panel-2 px-3 py-2 text-[13px] leading-6 text-text-dim">
                <span class="font-semibold text-text">原理:</span>{e.principle}
              </p>

              {e.safety && (
                <p class="mt-2 rounded-lg border border-charge-pos/40 bg-charge-pos/10 px-3 py-2 text-[13px] leading-6">
                  <span class="font-semibold text-charge-pos">⚠ 安全:</span>
                  <span class="text-text-dim">{e.safety}</span>
                </p>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <!-- ===== 高清素材下载 ===== -->
    <section id="downloads" class="mt-14 scroll-mt-24" aria-labelledby="dl-title">
      <h2 id="dl-title" class="text-2xl font-bold">高清素材下载</h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        {
          DOWNLOADS.map((d) => (
            <article class="rounded-xl border border-line bg-panel p-5">
              <h3 class="font-bold text-text">{d.title}</h3>
              <p class="mt-2 text-sm leading-7 text-text-dim">{d.desc}</p>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-[11px] text-text-dim">{d.format}</span>
                <span class="rounded-full bg-panel-2 px-2 py-0.5 text-[11px] text-text-dim">即将上线</span>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <footer class="border-t border-line py-8 text-center text-xs text-text-dim">
    <p>所有外部资源版权归原作者所有,本站仅作学习推荐。</p>
  </footer>
</BaseLayout>
