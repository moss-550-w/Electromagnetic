---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import Formula from '../../components/shared/Formula.astro';
import EMWaveDiagram from '../../components/shared/EMWaveDiagram.astro';
import {
  UNIFY_INTRO,
  MAXWELL_EQUATIONS,
  DOMINANCE,
  SYMMETRY_NOTE,
  VACUUM_FORMS,
  BEAUTY_REASONS,
  TRIBUTES,
} from '../../data/unification';
import { href } from '../../lib/href';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

const origin = Astro.site;
const abs = (p: string): string => (origin ? new URL(p, origin).href : p);
const pageUrl = abs(Astro.url.pathname);
const jsonLd = [
  articleSchema({
    headline: '殊途同归:麦克斯韦的统一',
    description: '四条分立定律如何汇入麦克斯韦方程组,它在电磁学的统治地位,以及它的对称性、艺术性——为什么它被称为「最优美的公式」。',
    url: pageUrl,
    section: '理论的诞生与争议',
  }),
  breadcrumbSchema([
    { name: '首页', url: abs(import.meta.env.BASE_URL) },
    { name: '理论的诞生与争议', url: abs(href('theory')) },
    { name: '殊途同归:麦克斯韦的统一', url: pageUrl },
  ]),
];

const feynman = TRIBUTES[0];
const others = TRIBUTES.slice(1);
---

<BaseLayout
  title="殊途同归:麦克斯韦的统一 · 理论的诞生与争议"
  description="四条分立定律如何汇入麦克斯韦方程组,它在电磁学的统治地位,以及它的对称性、艺术性——为什么它被称为「最优美的公式」。"
  type="article"
  jsonLd={jsonLd}
>
  <SiteNav />
  <main id="main" class="mx-auto max-w-4xl px-5 pb-24 pt-24">
    <a href={href('theory')} class="text-sm text-text-dim transition hover:text-arc-gold">← 理论与争议</a>

    <header class="mt-4 border-b border-line pb-8">
      <div class="text-sm font-bold text-arc-gold">万流归宗</div>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight md:text-5xl">殊途同归:麦克斯韦的统一</h1>
      <p class="mt-4 text-lg leading-relaxed text-text-dim">{UNIFY_INTRO}</p>
    </header>

    <!-- 一、四定律汇入四方程 -->
    <section class="mt-12" aria-labelledby="unify">
      <h2 id="unify" class="text-2xl font-bold">四条定律,汇成四个方程</h2>
      <p class="mt-2 text-sm text-text-dim">每一式,都收编了一条前驱定律。</p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {
          MAXWELL_EQUATIONS.map((eq, i) => (
            <figure class="rounded-xl border border-line bg-panel p-5">
              <div class="flex items-center gap-2">
                <span class="text-lg font-extrabold tabular-nums text-arc-gold">{i + 1}</span>
                <figcaption class="font-bold text-text">{eq.name}</figcaption>
              </div>
              <div class="my-3 overflow-x-auto">
                <Formula tex={eq.tex} display />
              </div>
              <div class="text-xs font-semibold text-charge-neg">{eq.origin}</div>
              <p class="mt-1 text-sm leading-7 text-text-dim">{eq.meaning}</p>
            </figure>
          ))
        }
      </div>
    </section>

    <!-- 二、统治地位 -->
    <section class="mt-14" aria-labelledby="dominance">
      <h2 id="dominance" class="text-2xl font-bold">电磁学的统治地位</h2>
      <p class="mt-3 text-[15px] leading-8 text-text">{DOMINANCE}</p>
      <blockquote class="mt-5 border-l-4 border-arc-gold bg-panel-2 px-5 py-4">
        <p class="text-lg font-semibold italic leading-relaxed text-text">「 {feynman.quote} 」</p>
        <footer class="mt-3 text-sm text-arc-gold">—— {feynman.author}</footer>
      </blockquote>
    </section>

    <!-- 三、对称性与艺术性 -->
    <section class="mt-14" aria-labelledby="symmetry">
      <h2 id="symmetry" class="text-2xl font-bold">对称性与艺术性</h2>
      <p class="mt-3 text-[15px] leading-8 text-text">{SYMMETRY_NOTE}</p>
      <div class="mt-5 rounded-xl border border-line bg-panel p-5">
        <div class="mb-3 text-xs uppercase tracking-wide text-text-dim">真空中的麦克斯韦方程组(ρ=0, J=0)</div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {
            VACUUM_FORMS.map((f) => (
              <div class="overflow-x-auto rounded-lg bg-panel-2 px-4 py-3">
                <Formula tex={f.tex} display />
              </div>
            ))
          }
        </div>
        <p class="mt-3 text-center text-[13px] text-text-dim">
          E 与 B 互为镜像、彼此激发——这就是电磁波,以光速 <span class="text-arc-gold">c = 1/√(μ₀ε₀)</span> 自持传播。
        </p>
      </div>

      <div class="mt-5">
        <EMWaveDiagram />
      </div>
    </section>

    <!-- 四、为什么最优美 -->
    <section class="mt-14" aria-labelledby="beauty">
      <h2 id="beauty" class="text-2xl font-bold">为什么它被称为「最优美的公式」</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          BEAUTY_REASONS.map((r) => (
            <article class="rounded-xl border border-line bg-panel p-5">
              <h3 class="text-lg font-bold text-arc-gold">{r.title}</h3>
              <p class="mt-2 text-sm leading-7 text-text-dim">{r.desc}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- 五、名家致敬 -->
    <section class="mt-14" aria-labelledby="tributes">
      <h2 id="tributes" class="text-2xl font-bold">他们这样评价它</h2>
      <div class="mt-6 flex flex-col gap-4">
        {
          others.map((t) => (
            <figure class="rounded-xl border border-line bg-panel p-6">
              <blockquote class="text-lg font-semibold italic leading-relaxed text-text">「 {t.quote} 」</blockquote>
              <figcaption class="mt-3 text-sm text-arc-gold">—— {t.author}</figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <nav class="mt-14 border-t border-line pt-6 text-sm">
      <a href={href('theory/maxwell-equations')} class="text-arc-gold hover:underline">回到麦克斯韦方程组 · 七段详解 →</a>
    </nav>
  </main>
</BaseLayout>
