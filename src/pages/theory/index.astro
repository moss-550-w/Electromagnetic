---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import { THEORIES } from '../../data/theories';
import { MUSEUM_INTRO } from '../../data/errors';
import { href } from '../../lib/href';
---

<BaseLayout
  title="理论的诞生与争议 · 电磁学认知革命"
  description="每个理所当然的公式,都曾是一场世纪之争。库仑定律、法拉第电磁感应、麦克斯韦方程组的诞生、争论与胜利,以及被推翻的错误理论博物馆。"
>
  <SiteNav />
  <main id="main" class="mx-auto max-w-5xl px-5 pb-24 pt-24">
    <header class="max-w-2xl">
      <h1 class="text-4xl font-extrabold md:text-5xl">理论的诞生与争议</h1>
      <p class="mt-4 text-lg text-text-dim">
        每个理所当然的公式背后,都是一场
        <span class="text-arc-gold">诞生、争论与胜利</span>
        的曲折历程。这里不只讲结论,更讲它如何被质疑、又如何最终站稳。
      </p>
    </header>

    <!-- 理论卡片 -->
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        THEORIES.map((t) => (
          <a
            href={href(`theory/${t.slug}`)}
            class="group rounded-2xl border border-line bg-panel p-6 transition hover:border-arc-gold/60 hover:bg-panel-2"
            style={`border-top:3px solid ${t.accent}`}
          >
            <div class="text-xs font-bold" style={`color:${t.accent}`}>
              {t.year} · {t.people.join('、')}
            </div>
            <h2 class="mt-1 text-xl font-bold group-hover:text-arc-gold">{t.name}</h2>
            <p class="mt-0.5 text-sm text-text-dim">{t.subtitle}</p>
            <p class="mt-3 text-sm leading-relaxed text-text-dim">{t.summary}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-arc-gold">展开七段 →</span>
          </a>
        ))
      }
    </div>

    <!-- 错误理论博物馆入口 -->
    <a
      href={href('theory/errors')}
      class="group mt-6 block rounded-2xl border border-charge-pos/40 bg-charge-pos/5 p-6 transition hover:border-charge-pos/70"
    >
      <h2 class="text-xl font-bold text-text group-hover:text-charge-pos">错误理论博物馆 →</h2>
      <p class="mt-2 max-w-3xl text-sm italic leading-relaxed text-text-dim">「 {MUSEUM_INTRO} 」</p>
      <p class="mt-2 text-xs text-text-dim">动物电 · 单/双流体说 · 超距作用 · 以太假说</p>
    </a>
  </main>
</BaseLayout>
