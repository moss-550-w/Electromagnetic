---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import WithoutEM from '../../components/engineering/WithoutEM.tsx';
import { ENGINEERING_CASES } from '../../data/engineering';
import { DISABLE_SCENARIOS, DISABLE_INTRO } from '../../data/disable';
import { href } from '../../lib/href';
---

<BaseLayout
  title="从公式到世界:工程应用史 · 电磁学"
  description="一个理论→一个发明→一个产业→改变人类生活。发电机与电网、无线电与通信的完整链条,以及「如果没有电磁学」互动模拟器。"
>
  <SiteNav />
  <main id="main" class="mx-auto max-w-5xl px-5 pb-24 pt-24">
    <header class="max-w-2xl">
      <h1 class="text-4xl font-extrabold md:text-5xl">从公式到世界</h1>
      <p class="mt-4 text-lg text-text-dim">
        打破「科学归科学、工程归工程」的割裂:一个理论 →
        <span class="text-arc-gold">一个发明 → 一个产业 → 改变人类生活</span>
        的完整链条。
      </p>
    </header>

    <!-- 案例卡 -->
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        ENGINEERING_CASES.map((c) => (
          <a
            href={href(`engineering/${c.slug}`)}
            class="group rounded-2xl border border-line bg-panel p-6 transition hover:border-arc-gold/60 hover:bg-panel-2"
            style={`border-top:3px solid ${c.accent}`}
          >
            <h2 class="text-xl font-bold group-hover:text-arc-gold">{c.name}</h2>
            <p class="mt-0.5 text-sm text-text-dim">{c.subtitle}</p>
            <div class="mt-3 flex flex-wrap items-center gap-1.5">
              {c.chain.map((node, i) => (
                <span class="inline-flex items-center gap-1.5">
                  <span class="rounded-full bg-panel-2 px-2.5 py-0.5 text-xs text-text-dim">{node}</span>
                  {i < c.chain.length - 1 && <span class="text-xs text-arc-gold">→</span>}
                </span>
              ))}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-text-dim">{c.summary}</p>
          </a>
        ))
      }
    </div>

    <!-- 如果没有电磁学:互动模拟器 -->
    <section id="simulator" class="mt-14 rounded-2xl border border-line bg-panel/40 p-6 md:p-8" aria-labelledby="sim-title">
      <h2 id="sim-title" class="text-2xl font-bold">如果没有电磁学</h2>
      <p class="mt-2 text-sm text-text-dim">{DISABLE_INTRO}</p>
      <div class="mt-6">
        <WithoutEM scenarios={DISABLE_SCENARIOS} client:visible />
      </div>
    </section>
  </main>
</BaseLayout>
